tième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>1</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>un,une</strong></text></td>\n<td style=\"text-align:center\"><strong>premier,première</strong></td>\n<td style=\"text-align:center\"><text class='green'>11</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>onze</strong></text></td>\n<td style=\"text-align:center\">onzième</td>\n<td style=\"text-align:center\"><text class='green'>21</text></td>\n<td style=\"text-align:center\"><text class='red'>v<strong>ingt et un</strong></text></td>\n<td style=\"text-align:center\">vingt et unième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>2</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>deux</strong></text></td>\n<td style=\"text-align:center\">deuxième</td>\n<td style=\"text-align:center\"><text class='green'>12</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>douze</strong></text></td>\n<td style=\"text-align:center\">douzième</td>\n<td style=\"text-align:center\"><text class='green'>22</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-deux</text></td>\n<td style=\"text-align:center\">vingt-deuxième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>3</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>trois</strong></text></td>\n<td style=\"text-align:center\">troisième</td>\n<td style=\"text-align:center\"><text class='green'>13</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>treize</strong></text></td>\n<td style=\"text-align:center\">treizième</td>\n<td style=\"text-align:center\"><text class='green'>23</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-trois</text></td>\n<td style=\"text-align:center\">vingt-troisième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>4</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>quatre</strong></text></td>\n<td style=\"text-align:center\">quatrième</td>\n<td style=\"text-align:center\"><text class='green'>14</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>qutorze</strong></text></td>\n<td style=\"text-align:center\">qutorzième</td>\n<td style=\"text-align:center\"><text class='green'>24</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-quatre</text></td>\n<td style=\"text-align:center\">vingt-quatrième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>5</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>cinq</strong></text></td>\n<td style=\"text-align:center\"><strong>cinquième</strong></td>\n<td style=\"text-align:center\"><text class='green'>15</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>quinze</strong></text></td>\n<td style=\"text-align:center\">quinzième</td>\n<td style=\"text-align:center\"><text class='green'>25</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-cinq</text></td>\n<td style=\"text-align:center\"><strong>vingt-cinquème</strong></td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>6</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>six</strong></text></td>\n<td style=\"text-align:center\">sixième</td>\n<td style=\"text-align:center\"><text class='green'>16</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>seize</strong></text></td>\n<td style=\"text-align:center\">seizième</td>\n<td style=\"text-align:center\"><text class='green'>26</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-six</text></td>\n<td style=\"text-align:center\">vingt-sixième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>7</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>sept</strong></text></td>\n<td style=\"text-align:center\">septième</td>\n<td style=\"text-align:center\"><text class='green'>17</text></td>\n<td style=\"text-align:center\"><text class='red'>dix-sept</text></td>\n<td style=\"text-align:center\">dix-septième</td>\n<td style=\"text-align:center\"><text class='green'>27</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-sept</text></td>\n<td style=\"text-align:center\">vingt-septième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>8</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>huit</strong></text></td>\n<td style=\"text-align:center\">huitième</td>\n<td style=\"text-align:center\"><text class='green'>18</text></td>\n<td style=\"text-align:center\"><text class='red'>dix-huit</text></td>\n<td style=\"text-align:center\">dix-huitième</td>\n<td style=\"text-align:center\"><text class='green'>28</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-huit</text></td>\n<td style=\"text-align:center\">vingt-huitième</td>\n</tr>\n<tr>\n<td style=\"text-align:center\"><text class='green'>9</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>neuf</strong></text></td>\n<td style=\"text-align:center\"><strong>neuvième</strong></td>\n<td style=\"text-align:center\"><text class='green'>19</text></td>\n<td style=\"text-align:center\"><text class='red'>dix-neuf</text></td>\n<td style=\"text-align:center\"><strong>dix-neuvième</strong></td>\n<td style=\"text-align:center\"><text class='green'>29</text></td>\n<td style=\"text-align:center\"><text class='red'>vingt-neuf</text></td>\n<td style=\"text-align:center\"><strong>vingt-neuvième</strong></td>\n</tr>\n<tr>\n<td style=\"text-align:center\">&lt;!–</td>\n<td style=\"text-align:center\"><text class='green'>10</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>dix</strong></text></td>\n<td style=\"text-align:center\">dixième</td>\n<td style=\"text-align:center\"><text class='green'>20</text></td>\n<td style=\"text-align:center\"><text class='red'><strong>vingt</strong></text></td>\n<td style=\"text-align:center\">vingtième</td>\n<td style=\"text-align:center\"><text class='green'>30</text></td>\n<td style=\"text-align:center\"><text class='red'>trente</text></td>\n</tr>\n</tbody>\n</table></div></div><p>序数词变化：基数词+ième<br>\n特殊：以e结尾要去掉e，cinq后加u，nuef的f变v加ième</p>\n<!-- |1|un|premier|\n|2|deux|deuxième|\n|3|trois|troisième|\n|4|quatre|quatrième|\n|5|cinq|cinquième|\n|6|six|sixième|\n|7|sept|septième|\n|8|huit|huitième|\n|9|neuf|neuvième|\n|10|dix|dixième|\n|11|onze|onzième|\n|12|douze|douzième|\n|13|treize|treizième|\n|14|qutorze|qutorzième|\n|15|quinze|quinzième|\n|16|seize|seizième|\n|17|dix-sept|dix-septième|\n|18|dix-huit|dix-huitième|\n|19|dix-neuf|dix-neuvième|\n|20|vingt|vingtième|\n|21|vingt et un|vingt et unième|\n|22|vingt-deux|vingt-deuxième|\n|23|vingt-trois|vingt-troisième|\n|24|vingt-quatre|vingt-quatrième|\n|25|vingt-cinq|vingt-cinquième|\n|26|vingt-six|vingt-sixième|\n|27|vingt-sept|vingt-septième|\n|28|vingt-huit|vingt-huitième|\n|29|vingt-neuf|vingt-neuvième|\n|30|trente|trentième| -->\n<!-- 30\n40\n50\n60\n70\n80\n90\n100\n1000 -->\n<h2 id=\"国家与国籍\">国家与国籍<a title=\"#国家与国籍\" href=\"#国家与国籍\"></a></h2>\n<!-- 标准法语 P/103 -->\n<h2 id=\"颜色\">颜色<a title=\"#颜色\" href=\"#颜色\"></a></h2>\n<h2 id=\"时间\">时间<a title=\"#时间\" href=\"#时间\"></a></h2>\n<p>le matin 早晨<br>\nmidi 正午<br>\nl’après-midi 下午<br>\nle soir 晚上<br>\nminuit 半夜</p>\n<h2 id=\"常见交通工具-prendre\">常见交通工具 prendre<a title=\"#常见交通工具-prendre\" href=\"#常见交通工具-prendre\"></a></h2>\n<p>avion: n.m. 飞机✈️<br>\ntrain: n.n. 火车🚄 TGV: train à grande vitesse<br>\nautobus(bus): n.m. 公共汽车🚌<br>\nmétro: n.m. 地铁🚇<br>\nbateau: n.m. 船🚢<br>\ntaxi: n.m. 出租车🚕<br>\nasscenseur: n.m. 电梯<br>\nescalier: n.m. 楼梯</p>\n<h2 id=\"词法\">词法<a title=\"#词法\" href=\"#词法\"></a></h2>\n<blockquote>\n<p><a href=\"/franch/vocabulary\">法语词类</a><br>\n<a href=\"/franch/conjugation\">动词变位</a></p>\n</blockquote>\n<h3 id=\"名词变复数规则\">名词变复数规则<a title=\"#名词变复数规则\" href=\"#名词变复数规则\"></a></h3>\n<ol>\n<li>大多数名词变复数时直接加s</li>\n<li>以 -s, -x, -z 结尾的名词形式不变</li>\n<li>以 -au, -eau, -eu 结尾的名词加x</li>\n<li>以 -al 结尾变 -aux</li>\n</ol>\n<h2 id=\"句法\">句法<a title=\"#句法\" href=\"#句法\"></a></h2>\n<p>P/109<br>\n主语    表示做某一动作，或处于某一状态的人或事物。主语可以是名词或代词<br>\n动词    动词表示主语的动作或状态<br>\n表语    某些表示状态的动词后面可以跟一个与主语有关的形容词或名词，这个形容词或名词叫做主语的表语<br>\n宾语    用来完成动词的意思，表示动作的对象<br>\n状语    用来修饰动词的词或词组，用来说明动词所表示的状态，动作的时间、地点、原因、方式等</p>\n","link":"franch","comments":true,"plink":"https://blog.vincenteliang.cn/franch/","toc":[{"id":"字母与发音","title":"字母与发音","index":"1","children":[{"id":"法语字母","title":"法语字母","index":"1.1"},{"id":"法语发音规则","title":"法语发音规则","index":"1.2"},{"id":"拼写符号","title":"拼写符号","index":"1.3"}]},{"id":"月份、星期与数字","title":"月份、星期与数字","index":"2","children":[{"id":"月份-mois-&lt;text-class='grey'&gt;n.m.-[mwa]&lt;/text&gt;","title":"月份 mois n.m. [mwa]","index":"2.1"},{"id":"星期-semaine-&lt;text-class='grey'&gt;n.f.-[s(ə)mεn]&lt;/text&gt;","title":"星期 semaine n.f. [s(ə)mεn]","index":"2.2"},{"id":"数字-chiffre-&lt;text-class='grey'&gt;n.m.-[∫ifr]&lt;/text&gt;","title":"数字 chiffre n.m. [∫ifr]","index":"2.3"}]},{"id":"国家与国籍","title":"国家与国籍","index":"3"},{"id":"颜色","title":"颜色","index":"4"},{"id":"时间","title":"时间","index":"5"},{"id":"常见交通工具-prendre","title":"常见交通工具 prendre","index":"6"},{"id":"词法","title":"词法","index":"7","children":[{"id":"名词变复数规则","title":"名词变复数规则","index":"7.1"}]},{"id":"句法","title":"句法","index":"8"}],"reward":true,"copyright":{"author":"Vincente Liang","link":"<a href=\"https://blog.vincenteliang.cn/franch/\" title=\"法语学习专栏\">https://blog.vincenteliang.cn/franch/</a>","license":"Attribution-NonCommercial-NoDerivatives 4.0 International (<a href=\\\"https://creativecommons.org/licenses/by-nc-sa/4.0/\\\" rel=\\\"external nofollow\\\" target=\\\"_blank\\\">CC BY-NC-ND 4.0</a>)","published":"June 9, 2020","updated":"February 2, 2020"}}